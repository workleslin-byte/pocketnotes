<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>The Pocket Notebook — Small books, big ideas</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;0,9..144,900;1,9..144,400;1,9..144,700&family=DM+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --cream:    #FAF3E3;
    --bone:     #F1E7CE;
    --ink:      #1A1A1A;
    --mustard:  #F5C13D;
    --coral:    #FF6B47;
    --sage:     #8FB89C;
    --sky:      #5BA8C9;
    --plum:     #6E3582;
    --hot-pink: #F26A8D;
    --olive:    #4A5238;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  html, body { overflow-x: hidden; }

  body {
    background: var(--cream);
    color: var(--ink);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 17px;
    line-height: 1.5;
    cursor: none;
  }

  /* Subtle paper grain */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.06;
    mix-blend-mode: multiply;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* Custom cursor */
  .cursor-dot, .cursor-ring {
    position: fixed;
    pointer-events: none;
    z-index: 10000;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: width .25s, height .25s, background .25s;
  }
  .cursor-dot {
    width: 8px; height: 8px;
    background: var(--ink);
  }
  .cursor-ring {
    width: 36px; height: 36px;
    border: 1.5px solid var(--ink);
    transition: width .3s ease, height .3s ease, transform .15s ease, border-color .25s, background .25s;
  }
  .cursor-ring.hover {
    width: 80px; height: 80px;
    background: var(--mustard);
    border-color: var(--mustard);
    mix-blend-mode: multiply;
  }

  @media (max-width: 900px) {
    body { cursor: default; }
    .cursor-dot, .cursor-ring { display: none; }
  }

  /* ─── NAV ─────────────────────────────── */
  nav {
    position: fixed;
    top: 1.5rem;
    left: 1.5rem;
    right: 1.5rem;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 1.5rem;
    background: var(--ink);
    color: var(--cream);
    border-radius: 999px;
    font-family: 'DM Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .nav-logo-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--mustard);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.4); }
  }

  .nav-links {
    display: flex;
    gap: 1.8rem;
    list-style: none;
  }
  .nav-links a {
    color: var(--cream);
    text-decoration: none;
    text-transform: uppercase;
    transition: color .25s;
    cursor: none;
  }
  .nav-links a:hover { color: var(--mustard); }

  .nav-cta {
    background: var(--mustard);
    color: var(--ink);
    padding: 0.5rem 1.2rem;
    border-radius: 999px;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 500;
    transition: background .25s;
    cursor: none;
  }
  .nav-cta:hover { background: var(--coral); color: var(--cream); }

  /* ─── HERO ─────────────────────────────── */
  .hero {
    min-height: 100vh;
    padding: 8rem 5vw 4rem;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .hero-eyebrow::before {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--ink);
  }

  .hero-title {
    font-family: 'Fraunces', serif;
    font-weight: 900;
    font-size: clamp(4rem, 13vw, 14rem);
    line-height: 0.88;
    letter-spacing: -0.04em;
    margin-bottom: 2rem;
    position: relative;
  }

  .hero-title .word {
    display: inline-block;
    transition: transform .4s cubic-bezier(.22,1,.36,1), color .3s;
  }
  .hero-title .word:hover {
    transform: rotate(-3deg) scale(1.05);
    color: var(--coral);
  }

  .hero-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--coral);
  }

  .hero-meta {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: end;
    margin-top: 2rem;
  }

  .hero-blurb {
    max-width: 460px;
    font-size: 1.15rem;
    line-height: 1.55;
    color: var(--ink);
  }

  .hero-blurb strong {
    background: var(--mustard);
    padding: 0 0.3em;
    font-weight: 500;
  }

  .hero-stamp {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero-stamp svg {
    width: 80px;
    height: 80px;
    animation: spin 18s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Floating illustrations in hero */
  .float {
    position: absolute;
    pointer-events: none;
    animation: bob 6s ease-in-out infinite;
  }
  .float:nth-child(1) { animation-delay: 0s; }
  .float:nth-child(2) { animation-delay: -2s; }
  .float:nth-child(3) { animation-delay: -4s; }

  @keyframes bob {
    0%, 100% { transform: translateY(0) rotate(var(--rot, 0deg)); }
    50%      { transform: translateY(-18px) rotate(calc(var(--rot, 0deg) + 5deg)); }
  }

  .float-1 { top: 12%; right: 8%; --rot: -8deg; }
  .float-2 { top: 55%; right: 22%; --rot: 12deg; }
  .float-3 { bottom: 8%; right: 6%; --rot: -3deg; }

  /* ─── MARQUEE ─────────────────────────────── */
  .marquee {
    background: var(--ink);
    color: var(--cream);
    padding: 1.4rem 0;
    overflow: hidden;
    white-space: nowrap;
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
  }

  .marquee-track {
    display: inline-flex;
    gap: 3rem;
    align-items: center;
    animation: marquee 28s linear infinite;
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 2rem;
    font-weight: 400;
  }

  .marquee-track .star {
    color: var(--mustard);
    font-style: normal;
    display: inline-block;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ─── PRODUCTS ─────────────────────────────── */
  .products {
    padding: 8rem 5vw;
    position: relative;
  }

  .section-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    margin-bottom: 5rem;
    gap: 2rem;
  }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .section-label::before {
    content: '※ ';
    color: var(--coral);
  }

  .section-title {
    font-family: 'Fraunces', serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
  }

  .section-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--plum);
  }

  .section-aside {
    font-size: 1.05rem;
    max-width: 360px;
    color: var(--ink);
    opacity: 0.8;
  }

  .product-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  .product {
    cursor: none;
    transition: transform .35s cubic-bezier(.22,1,.36,1);
  }
  .product:hover { transform: translateY(-12px); }

  .product-frame {
    aspect-ratio: 4/5;
    border-radius: 32px;
    padding: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.2rem;
    position: relative;
    overflow: hidden;
    transition: border-radius .4s;
  }
  .product:hover .product-frame { border-radius: 12px; }

  .product-frame.f1 { background: var(--mustard); }
  .product-frame.f2 { background: var(--coral); }
  .product-frame.f3 { background: var(--sage); }

  .product-tag {
    position: absolute;
    top: 1.2rem;
    left: 1.2rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--cream);
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
  }

  .product-info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0 0.5rem;
  }

  .product-name {
    font-family: 'Fraunces', serif;
    font-size: 1.4rem;
    font-weight: 700;
  }
  .product-name em { font-style: italic; font-weight: 400; }

  .product-price {
    font-family: 'DM Mono', monospace;
    font-size: 0.95rem;
  }

  .product-desc {
    margin-top: 0.4rem;
    padding: 0 0.5rem;
    font-size: 0.95rem;
    color: var(--ink);
    opacity: 0.7;
    font-style: italic;
  }

  /* ─── PHILOSOPHY ─────────────────────────────── */
  .philosophy {
    background: var(--plum);
    color: var(--cream);
    padding: 8rem 5vw;
    position: relative;
    overflow: hidden;
  }

  .philosophy .section-label,
  .philosophy .section-aside { color: var(--bone); }
  .philosophy .section-label::before { color: var(--mustard); }
  .philosophy .section-title em { color: var(--mustard); }

  .philo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 5rem 4rem;
    margin-top: 4rem;
    position: relative;
    z-index: 2;
  }

  .philo-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .philo-num {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 4rem;
    line-height: 0.9;
    color: var(--mustard);
  }

  .philo-content h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    line-height: 1.15;
  }

  .philo-content p {
    color: var(--bone);
    line-height: 1.6;
    opacity: 0.9;
  }

  .philo-deco {
    position: absolute;
    pointer-events: none;
    opacity: 0.18;
  }
  .philo-deco-1 { top: 10%; right: -3%; transform: rotate(15deg); }
  .philo-deco-2 { bottom: 8%; left: -2%; transform: rotate(-10deg); }

  /* ─── WRITING ─────────────────────────────── */
  .writing {
    padding: 8rem 5vw;
  }

  .writing-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 2rem;
    margin-top: 4rem;
  }

  .post {
    cursor: none;
    transition: transform .35s cubic-bezier(.22,1,.36,1);
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .post:hover { transform: translateY(-8px); }

  .post-img {
    aspect-ratio: 4/3;
    border-radius: 20px;
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: border-radius .4s;
    position: relative;
  }
  .post:hover .post-img { border-radius: 8px; }

  .post-img.bg-mustard { background: var(--mustard); }
  .post-img.bg-coral { background: var(--coral); }
  .post-img.bg-sage  { background: var(--sage); }
  .post-img.bg-sky   { background: var(--sky); }
  .post-img.bg-pink  { background: var(--hot-pink); }

  .post-meta {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
    color: var(--ink);
    opacity: 0.6;
  }

  .post-title {
    font-family: 'Fraunces', serif;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .post.large { grid-column: span 7; }
  .post.large .post-img { aspect-ratio: 16/10; }
  .post.large .post-title { font-size: 2.4rem; }
  .post.medium { grid-column: span 5; }
  .post.medium .post-title { font-size: 1.8rem; }
  .post.small { grid-column: span 4; }

  /* ─── ABOUT/CTA STRIP ─────────────────────────────── */
  .strip {
    background: var(--mustard);
    padding: 6rem 5vw;
    position: relative;
    overflow: hidden;
  }

  .strip-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .strip-title {
    font-family: 'Fraunces', serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
  }
  .strip-title em { font-style: italic; font-weight: 400; color: var(--plum); }

  .strip-action {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .strip-button {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    background: var(--ink);
    color: var(--cream);
    text-decoration: none;
    padding: 1.3rem 2.2rem;
    border-radius: 999px;
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: none;
    transition: transform .25s, background .25s;
  }
  .strip-button:hover {
    transform: translateX(8px);
    background: var(--coral);
  }
  .strip-button .arrow {
    transition: transform .25s;
  }
  .strip-button:hover .arrow {
    transform: translateX(4px) rotate(-45deg);
  }

  .strip-deco {
    position: absolute;
    right: -50px;
    bottom: -50px;
    opacity: 0.2;
    pointer-events: none;
  }

  /* ─── FOOTER ─────────────────────────────── */
  footer {
    background: var(--ink);
    color: var(--cream);
    padding: 5rem 5vw 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .footer-brand-title {
    font-family: 'Fraunces', serif;
    font-weight: 900;
    font-size: 3rem;
    line-height: 1;
    margin-bottom: 1rem;
  }
  .footer-brand-title em { font-style: italic; font-weight: 400; color: var(--mustard); }

  .footer-brand p {
    color: var(--bone);
    opacity: 0.7;
    max-width: 320px;
  }

  .footer-col h4 {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mustard);
    margin-bottom: 1.2rem;
  }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; }
  .footer-col a { color: var(--bone); text-decoration: none; font-size: 0.95rem; transition: color .2s; cursor: none; }
  .footer-col a:hover { color: var(--mustard); }

  .footer-bottom {
    border-top: 1px solid rgba(241,231,206,0.15);
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: var(--bone);
    opacity: 0.6;
  }

  /* ─── RESPONSIVE ─────────────────────────────── */
  @media (max-width: 900px) {
    nav { padding: 0.7rem 1rem; }
    .nav-links { display: none; }
    .hero { padding: 7rem 6vw 3rem; }
    .hero-meta { grid-template-columns: 1fr; gap: 2rem; }
    .float { display: none; }
    .section-head { grid-template-columns: 1fr; }
    .product-row { grid-template-columns: 1fr; gap: 2rem; }
    .philo-grid { grid-template-columns: 1fr; gap: 3rem; }
    .writing-grid { grid-template-columns: 1fr; }
    .post.large, .post.medium, .post.small { grid-column: span 1; }
    .post.large .post-title { font-size: 1.8rem; }
    .strip-content { grid-template-columns: 1fr; gap: 2rem; }
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer-bottom { flex-direction: column; gap: 0.8rem; }
    .marquee-track { font-size: 1.4rem; gap: 2rem; }
  }

  /* ─── REVEAL ANIMATION ─────────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity .8s ease, transform .8s cubic-bezier(.22,1,.36,1);
  }
  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }
</style>
</head>
<body>

<!-- Custom cursor -->
<div class="cursor-ring" id="cursorRing"></div>
<div class="cursor-dot" id="cursorDot"></div>

<!-- Nav -->
<nav>
  <div class="nav-logo">
    <span class="nav-logo-dot"></span>
    <span>Pocket Notebook</span>
  </div>
  <ul class="nav-links">
    <li><a href="#shop">Shop</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#writing">Writing</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="#shop" class="nav-cta">Buy a notebook ↗</a>
</nav>

<!-- ─── HERO ────────────────────────────────────── -->
<section class="hero">

  <!-- Floating SVG illustrations -->
  <div class="float float-1">
    <!-- Pencil character -->
    <svg width="140" height="180" viewBox="0 0 140 180" xmlns="http://www.w3.org/2000/svg">
      <!-- Pencil body -->
      <rect x="40" y="40" width="60" height="110" fill="#F5C13D" stroke="#1A1A1A" stroke-width="3"/>
      <!-- Tip -->
      <polygon points="40,150 100,150 70,180" fill="#FAF3E3" stroke="#1A1A1A" stroke-width="3"/>
      <polygon points="55,165 85,165 70,180" fill="#1A1A1A"/>
      <!-- Eraser -->
      <rect x="40" y="20" width="60" height="20" fill="#FF6B47" stroke="#1A1A1A" stroke-width="3"/>
      <rect x="40" y="32" width="60" height="8" fill="#1A1A1A"/>
      <!-- Eyes -->
      <circle cx="58" cy="80" r="5" fill="#1A1A1A"/>
      <circle cx="82" cy="80" r="5" fill="#1A1A1A"/>
      <circle cx="60" cy="78" r="1.5" fill="#FAF3E3"/>
      <circle cx="84" cy="78" r="1.5" fill="#FAF3E3"/>
      <!-- Smile -->
      <path d="M55 100 Q70 112 85 100" stroke="#1A1A1A" stroke-width="3" fill="none" stroke-linecap="round"/>
      <!-- Cheeks -->
      <circle cx="50" cy="95" r="3" fill="#FF6B47" opacity="0.6"/>
      <circle cx="90" cy="95" r="3" fill="#FF6B47" opacity="0.6"/>
    </svg>
  </div>

  <div class="float float-2">
    <!-- Squiggle star -->
    <svg width="90" height="90" viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg">
      <path d="M45 5 L52 35 L82 38 L58 55 L66 84 L45 67 L24 84 L32 55 L8 38 L38 35 Z"
            fill="#F26A8D" stroke="#1A1A1A" stroke-width="3" stroke-linejoin="round"/>
      <circle cx="45" cy="48" r="6" fill="#1A1A1A"/>
    </svg>
  </div>

  <div class="float float-3">
    <!-- Open notebook with pages -->
    <svg width="130" height="120" viewBox="0 0 130 120" xmlns="http://www.w3.org/2000/svg">
      <!-- Shadow -->
      <path d="M15 95 Q65 105 115 95 L115 105 Q65 115 15 105 Z" fill="#1A1A1A" opacity="0.15"/>
      <!-- Left page -->
      <path d="M10 25 Q30 20 65 30 L65 95 Q30 90 10 95 Z" fill="#FAF3E3" stroke="#1A1A1A" stroke-width="3"/>
      <!-- Right page -->
      <path d="M120 25 Q100 20 65 30 L65 95 Q100 90 120 95 Z" fill="#FAF3E3" stroke="#1A1A1A" stroke-width="3"/>
      <!-- Lines -->
      <line x1="20" y1="45" x2="55" y2="48" stroke="#5BA8C9" stroke-width="2"/>
      <line x1="20" y1="55" x2="55" y2="58" stroke="#5BA8C9" stroke-width="2"/>
      <line x1="20" y1="65" x2="50" y2="68" stroke="#5BA8C9" stroke-width="2"/>
      <line x1="75" y1="48" x2="110" y2="45" stroke="#5BA8C9" stroke-width="2"/>
