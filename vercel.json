    { "source": "/essays/the-roman-wax-tablet.html", "destination": "/essays/the-roman-wax-tablet", "permanent": true },
    { "source": "/essays/two-lines-every-day.html", "destination": "/essays/two-lines-every-day", "permanent": true },
