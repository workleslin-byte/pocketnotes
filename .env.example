# Database — Neon Postgres (provisioned via Vercel Marketplace)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Payload — admin auth secret (generate: openssl rand -base64 32)
PAYLOAD_SECRET=replace_me_with_random_64_char_string

# Resend — transactional + broadcast email
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hello@pocketnotes.in
RESEND_FROM_NAME=Pocket Notes
RESEND_AUDIENCE_ID=

# Site
NEXT_PUBLIC_SITE_URL=https://www.pocketnotes.in
PAYLOAD_PUBLIC_SERVER_URL=https://www.pocketnotes.in

# Vercel Blob (optional — for media storage in production)
BLOB_READ_WRITE_TOKEN=
